#!/usr/bin/env python3
"""today — CLI for the Today Tasks widget.

  today                    list tasks
  today add TEXT...        add a task
  today done N [N...]      check off task N (number from `today`)
  today undo N [N...]      un-check task N
  today rm N [N...]        delete task N
  today clear              remove all checked-off tasks
  today note N TEXT...     set task N's note (links/URLs allowed)
  today note+ N TEXT...    append a line to task N's note
  today note- N            clear task N's note
  today when N WHEN        reschedule: today | tomorrow | +3 | 2026-07-30

Apple Reminders sync (two-way, opt-in):
  today sync               sync now with the linked Reminders list
  today sync on|off        turn automatic syncing on or off
  today sync list NAME     choose which Reminders list to link
  today sync status        show the current setting

`today add` accepts the same WHEN as a trailing flag:
  today add "Order primers" --when tomorrow
  today add "Passage PDOs" --when +3

The widget watches the data file and updates within ~2 seconds.
"""

import datetime
import errno
import fcntl
import json
import os
import subprocess
import sys
import time

DATA_DIR = os.path.expanduser("~/Library/Application Support/TodayTasks")
DATA_FILE = os.path.join(DATA_DIR, "tasks.json")


def today_str():
    return datetime.date.today().isoformat()


def load():
    try:
        with open(DATA_FILE) as f:
            state = json.load(f)
    except Exception:
        state = {"date": today_str(), "tasks": [], "pinned": True}
    if state.get("date") != today_str():
        state["tasks"] = [t for t in state.get("tasks", []) if not t.get("done")]
        state["date"] = today_str()
    state.setdefault("tasks", [])
    for t in state["tasks"]:
        t.setdefault("due", state.get("date", today_str()))
    return state


def save(state):
    os.makedirs(DATA_DIR, exist_ok=True)
    tmp = DATA_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, DATA_FILE)


def parse_when(w):
    w = w.strip().lower()
    today = datetime.date.today()
    if w in ("today", "now"):
        return today.isoformat()
    if w in ("tomorrow", "tmrw"):
        return (today + datetime.timedelta(days=1)).isoformat()
    if w.startswith(("+", "-")):
        try:
            return (today + datetime.timedelta(days=int(w))).isoformat()
        except ValueError:
            pass
    try:
        return datetime.date.fromisoformat(w).isoformat()
    except ValueError:
        sys.exit("Don't understand when=%r (use today|tomorrow|+3|YYYY-MM-DD)" % w)


# ---------------------------------------------------------------- Reminders

SEP = "\x1f"  # unit separator: safe inside reminder titles


def osa(script):
    r = subprocess.run(
        ["osascript", "-e", script], capture_output=True, text=True, timeout=90
    )
    if r.returncode != 0:
        err = (r.stderr or "").strip()
        if "-1743" in err or "not allowed" in err.lower():
            sys.exit(
                "Reminders access was denied.\n"
                "Allow it in System Settings > Privacy & Security > Automation,\n"
                "then run `today sync` again."
            )
        sys.exit("Reminders error: %s" % (err or "unknown"))
    return r.stdout.strip()


def rem_fetch(list_name):
    """Every reminder in the list: id, title, completed, due date."""
    script = '''
    tell application "Reminders"
      set out to ""
      repeat with r in reminders of list "%s"
        set d to due date of r
        if d is missing value then
          set ds to ""
        else
          set ds to (year of d as string) & "-" & ¬
            text -2 thru -1 of ("0" & ((month of d) as integer)) & "-" & ¬
            text -2 thru -1 of ("0" & (day of d))
        end if
        set out to out & (id of r) & "%s" & (name of r) & "%s" & ¬
          (completed of r as string) & "%s" & ds & linefeed
      end repeat
      return out
    end tell''' % (list_name.replace('"', '\\"'), SEP, SEP, SEP)
    def parse(out):
        rows = []
        for line in out.splitlines():
            parts = line.split(SEP)
            if len(parts) == 4:
                rows.append({
                    "rid": parts[0], "text": parts[1],
                    "done": parts[2].strip().lower() == "true",
                    "due": parts[3].strip() or None,
                })
        return rows

    rows = parse(osa(script))
    # Reminders.app answers with nothing while it is busy writing. An empty
    # answer is indistinguishable from a genuinely empty list, and acting on it
    # would re-create every task, so confirm empties before believing them.
    for _ in range(3):
        if rows:
            break
        time.sleep(1.5)
        rows = parse(osa(script))
    return rows


def _due_clause(due):
    if not due:
        return ""
    y, m, d = due.split("-")
    return (
        ', due date:(current date) - (time of (current date)) + 9 * hours '
        '+ 0 * days'
    ) if False else (
        ', due date:(my makeDate(%s, %s, %s))' % (int(y), int(m), int(d))
    )


MAKE_DATE = '''
on makeDate(y, m, d)
  set dd to current date
  set year of dd to y
  set month of dd to m
  set day of dd to d
  set time of dd to 9 * hours
  return dd
end makeDate
'''


def rem_create(list_name, text, due):
    script = MAKE_DATE + '''
    tell application "Reminders"
      set r to make new reminder at end of list "%s" with properties {name:"%s"%s}
      return id of r
    end tell''' % (
        list_name.replace('"', '\\"'),
        text.replace("\\", "\\\\").replace('"', '\\"'),
        _due_clause(due),
    )
    return osa(script)


def rem_update(rid, done=None, text=None, due=None):
    sets = []
    if done is not None:
        sets.append("set completed of r to %s" % ("true" if done else "false"))
    if text is not None:
        sets.append('set name of r to "%s"' % text.replace("\\", "\\\\").replace('"', '\\"'))
    if due is not None:
        y, m, d = due.split("-")
        sets.append("set due date of r to (my makeDate(%d, %d, %d))" % (int(y), int(m), int(d)))
    if not sets:
        return
    script = MAKE_DATE + '''
    tell application "Reminders"
      set r to first reminder whose id is "%s"
      %s
    end tell''' % (rid, "\n      ".join(sets))
    osa(script)


LOCK_FILE = os.path.join(DATA_DIR, "sync.lock")


def sync(_ignored=None, verbose=True):
    """Two-way sync between the widget and one Reminders list.

    Holds an exclusive lock and re-reads state inside it, so a manual `today
    sync` and the app's background sync can never duplicate each other's work.
    """
    os.makedirs(DATA_DIR, exist_ok=True)
    lock = open(LOCK_FILE, "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except IOError as e:
        if e.errno in (errno.EAGAIN, errno.EACCES):
            if verbose:
                print("Another sync is already running; skipped.")
            return load()
        raise
    try:
        return _sync_locked(verbose)
    finally:
        fcntl.flock(lock, fcntl.LOCK_UN)
        lock.close()


def _sync_locked(verbose):
    state = load()  # fresh read inside the lock
    list_name = state.get("remindersList")
    if not list_name:
        sys.exit("No list linked yet. Run: today sync list \"Tasks\"")
    remote = {r["rid"]: r for r in rem_fetch(list_name)}
    tasks = state["tasks"]
    today = today_str()
    created = updated = imported = dropped = adopted = 0

    # Safety net: if we already linked reminders but the list reads as empty,
    # something is wrong with Reminders rather than genuinely empty. Bail out
    # instead of duplicating everything or wiping the links.
    if not remote and any(t.get("rid") for t in tasks):
        if verbose:
            print("Reminders returned an empty list unexpectedly; skipped this sync.")
        return state

    # Reminders that no task claims yet, keyed by title — lets a task adopt an
    # existing reminder instead of creating a duplicate.
    claimed = {t.get("rid") for t in tasks if t.get("rid")}
    unclaimed = {}
    for rid, r in remote.items():
        if rid not in claimed:
            unclaimed.setdefault(r["text"].strip(), []).append(rid)

    # widget -> Reminders
    for t in tasks:
        rid = t.get("rid")
        if not rid:
            same = unclaimed.get((t.get("text") or "").strip())
            if same:
                t["rid"] = rid = same.pop(0)
                adopted += 1
        if rid and rid in remote:
            r = remote[rid]
            changes = {}
            if bool(t.get("done")) != r["done"]:
                changes["done"] = bool(t.get("done"))
            if t.get("text") != r["text"]:
                changes["text"] = t.get("text")
            if t.get("due") and t["due"] != r["due"]:
                changes["due"] = t["due"]
            if changes:
                rem_update(rid, **changes)
                updated += 1
        elif rid:
            # the reminder was deleted in Reminders.app
            t["_gone"] = True
            dropped += 1
        else:
            t["rid"] = rem_create(list_name, t.get("text", ""), t.get("due"))
            created += 1

    if dropped:
        state["tasks"] = [t for t in tasks if not t.get("_gone")]
        tasks = state["tasks"]

    # Reminders -> widget
    known = {t.get("rid") for t in tasks}
    for rid, r in remote.items():
        if rid in known:
            continue
        if r["done"]:
            continue  # don't import already-finished reminders
        tasks.append({
            "id": format(int(time.time() * 1000), "x") + str(imported),
            "text": r["text"], "done": False,
            "due": r["due"] or today, "rid": rid,
        })
        imported += 1

    # completion coming from Reminders
    for t in tasks:
        r = remote.get(t.get("rid"))
        if r and r["done"] and not t.get("done"):
            t["done"] = True
            t.setdefault("doneAt", time.strftime("%H:%M"))
            t.setdefault("doneOn", today)

    save(state)
    if verbose:
        bits = []
        for n, label in ((created, "created"), (imported, "imported"),
                         (adopted, "matched"), (updated, "updated"),
                         (dropped, "removed")):
            if n:
                bits.append("%d %s" % (n, label))
        print("Synced with \"%s\": %s" % (list_name, ", ".join(bits) or "already in sync"))
    return state


def show(state):
    tasks = state["tasks"]
    if not tasks:
        print("No tasks.")
        return
    today = today_str()
    buckets = [
        ("CARRIED OVER", lambda t: not t.get("done") and t.get("due", today) < today),
        ("TODAY", lambda t: not t.get("done") and t.get("due", today) == today),
        ("UPCOMING", lambda t: not t.get("done") and t.get("due", today) > today),
        ("DONE", lambda t: t.get("done")),
    ]
    open_n = sum(1 for t in tasks if not t.get("done") and t.get("due", today) <= today)
    done_n = sum(1 for t in tasks if t.get("done"))
    print("Today  (%d done, %d open)" % (done_n, open_n))
    for label, pred in buckets:
        rows = [(i, t) for i, t in enumerate(tasks, 1) if pred(t)]
        if not rows:
            continue
        print("\n  %s" % label)
        for i, t in rows:
            mark = "x" if t.get("done") else " "
            due = t.get("due", today)
            tag = ""
            if not t.get("done") and due != today:
                tag = "  (%s)" % due
            print("  %2d. [%s] %s%s" % (i, mark, t.get("text", ""), tag))
            for line in (t.get("note") or "").splitlines():
                if line.strip():
                    print("        | %s" % line.strip())


def pick(state, args):
    idxs = []
    for a in args:
        try:
            n = int(a)
        except ValueError:
            sys.exit("Not a task number: %r (run `today` to see numbers)" % a)
        if not 1 <= n <= len(state["tasks"]):
            sys.exit("No task #%d (there are %d tasks)" % (n, len(state["tasks"])))
        idxs.append(n - 1)
    return idxs


def main():
    state = load()
    args = sys.argv[1:]
    cmd = args[0] if args else "list"

    if cmd == "list" or not args:
        show(state)
        return
    if cmd == "add":
        rest = args[1:]
        due = today_str()
        for flag in ("--when", "--on", "--in"):
            if flag in rest:
                k = rest.index(flag)
                if k + 1 >= len(rest):
                    sys.exit("Usage: today add TEXT %s WHEN" % flag)
                due = parse_when(rest[k + 1])
                rest = rest[:k] + rest[k + 2:]
        text = " ".join(rest).strip()
        if not text:
            sys.exit("Usage: today add TEXT [--when tomorrow|+3|YYYY-MM-DD]")
        state["tasks"].append({
            "id": format(int(time.time() * 1000), "x"),
            "text": text, "done": False, "due": due,
        })
    elif cmd in ("done", "undo"):
        for i in pick(state, args[1:]):
            state["tasks"][i]["done"] = cmd == "done"
            if cmd == "done":
                state["tasks"][i]["doneAt"] = time.strftime("%H:%M")
            else:
                state["tasks"][i].pop("doneAt", None)
    elif cmd == "rm":
        for i in sorted(pick(state, args[1:]), reverse=True):
            del state["tasks"][i]
    elif cmd == "clear":
        state["tasks"] = [t for t in state["tasks"] if not t.get("done")]
    elif cmd == "sync":
        sub = args[1] if len(args) > 1 else ""
        if sub == "list":
            if len(args) < 3:
                sys.exit('Usage: today sync list "Tasks"')
            name = " ".join(args[2:])
            names = [n.strip() for n in osa(
                'tell application "Reminders" to get name of every list'
            ).split(",")]
            if name not in names:
                sys.exit("No Reminders list called %r. Yours: %s" % (name, ", ".join(names)))
            state["remindersList"] = name
            state["syncOn"] = True
            save(state)
            print('Linked to "%s". Syncing now…' % name)
            state = sync()
            show(state)
            return
        elif sub in ("on", "off"):
            state["syncOn"] = sub == "on"
            if sub == "on" and not state.get("remindersList"):
                sys.exit('Pick a list first: today sync list "Tasks"')
            save(state)
            print("Automatic sync %s" % ("ON (every 60s)" if sub == "on" else "OFF"))
            return
        elif sub == "status":
            print("List:  %s" % (state.get("remindersList") or "(none linked)"))
            print("Auto:  %s" % ("on" if state.get("syncOn") else "off"))
            linked = sum(1 for t in state["tasks"] if t.get("rid"))
            print("Linked tasks: %d of %d" % (linked, len(state["tasks"])))
            return
        else:
            show(sync())
            return
    elif cmd == "when":
        if len(args) < 3:
            sys.exit("Usage: today when N today|tomorrow|+3|YYYY-MM-DD")
        i = pick(state, args[1:2])[0]
        state["tasks"][i]["due"] = parse_when(args[2])
    elif cmd in ("note", "note+", "note-"):
        if len(args) < 2:
            sys.exit("Usage: today %s N [TEXT...]" % cmd)
        i = pick(state, args[1:2])[0]
        text = " ".join(args[2:]).strip()
        if cmd == "note-":
            state["tasks"][i].pop("note", None)
        elif cmd == "note+":
            old = state["tasks"][i].get("note", "")
            state["tasks"][i]["note"] = (old + "\n" + text).strip() if old else text
        else:
            if not text:
                sys.exit("Usage: today note N TEXT")
            state["tasks"][i]["note"] = text
    else:
        sys.exit(__doc__.strip())

    save(state)
    show(state)


if __name__ == "__main__":
    main()
