#!/usr/bin/env python3
"""today — CLI for the Today Tasks widget.

  today                    list tasks
  today add TEXT...        add a task
  today done N [N...]      check off task N (number from `today`)
  today undo N [N...]      un-check task N
  today rm N [N...]        delete task N
  today clear              remove all checked-off tasks
  today note N TEXT...     set task N's note (links/URLs allowed)
  today note+ N TEXT...    append a line to task N's note
  today note- N            clear task N's note
  today when N WHEN        reschedule: today | tomorrow | +3 | 2026-07-30

Apple Reminders sync (two-way, opt-in):
  today sync               sync now with the linked Reminders list
  today sync on|off        turn automatic syncing on or off
  today sync list NAME     choose which Reminders list to link
  today sync status        show the current setting

Shared list via Notion (two-way, for coworkers):
  today share new NAME     create a shared Notion database and link it
  today share join DBID    link an existing shared database (the coworker path)
  today share sync         sync the shared list now
  today share status       show the shared-list setting
  today share off          stop syncing the shared list
  today add "..." --shared add straight to the shared list
  today share N            move task N into the shared list
  today unshare N          move task N back to personal

`today add` accepts the same WHEN as a trailing flag:
  today add "Order primers" --when tomorrow
  today add "Passage PDOs" --when +3

The widget watches the data file and updates within ~2 seconds.
"""

import datetime
import errno
import fcntl
import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.request

DATA_DIR = os.path.expanduser("~/Library/Application Support/TodayTasks")
DATA_FILE = os.path.join(DATA_DIR, "tasks.json")
NOTION_TOKEN_FILE = os.path.expanduser("~/.notion_token")


def today_str():
    return datetime.date.today().isoformat()


def load():
    try:
        with open(DATA_FILE) as f:
            state = json.load(f)
    except Exception:
        state = {"date": today_str(), "tasks": [], "pinned": True}
    if state.get("date") != today_str():
        state["tasks"] = [t for t in state.get("tasks", []) if not t.get("done")]
        state["date"] = today_str()
    state.setdefault("tasks", [])
    for t in state["tasks"]:
        t.setdefault("due", state.get("date", today_str()))
    return state


def save(state):
    os.makedirs(DATA_DIR, exist_ok=True)
    tmp = DATA_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, DATA_FILE)


def parse_when(w):
    w = w.strip().lower()
    today = datetime.date.today()
    if w in ("today", "now"):
        return today.isoformat()
    if w in ("tomorrow", "tmrw"):
        return (today + datetime.timedelta(days=1)).isoformat()
    if w.startswith(("+", "-")):
        try:
            return (today + datetime.timedelta(days=int(w))).isoformat()
        except ValueError:
            pass
    try:
        return datetime.date.fromisoformat(w).isoformat()
    except ValueError:
        sys.exit("Don't understand when=%r (use today|tomorrow|+3|YYYY-MM-DD)" % w)


# ---------------------------------------------------------------- Reminders

SEP = "\x1f"  # unit separator: safe inside reminder titles


def osa(script):
    r = subprocess.run(
        ["osascript", "-e", script], capture_output=True, text=True, timeout=90
    )
    if r.returncode != 0:
        err = (r.stderr or "").strip()
        if "-1743" in err or "not allowed" in err.lower():
            sys.exit(
                "Reminders access was denied.\n"
                "Allow it in System Settings > Privacy & Security > Automation,\n"
                "then run `today sync` again."
            )
        sys.exit("Reminders error: %s" % (err or "unknown"))
    return r.stdout.strip()


def rem_fetch(list_name):
    """Every reminder in the list: id, title, completed, due date."""
    script = '''
    tell application "Reminders"
      set out to ""
      repeat with r in reminders of list "%s"
        set d to due date of r
        if d is missing value then
          set ds to ""
        else
          set ds to (year of d as string) & "-" & ¬
            text -2 thru -1 of ("0" & ((month of d) as integer)) & "-" & ¬
            text -2 thru -1 of ("0" & (day of d))
        end if
        set out to out & (id of r) & "%s" & (name of r) & "%s" & ¬
          (completed of r as string) & "%s" & ds & linefeed
      end repeat
      return out
    end tell''' % (list_name.replace('"', '\\"'), SEP, SEP, SEP)
    def parse(out):
        rows = []
        for line in out.splitlines():
            parts = line.split(SEP)
            if len(parts) == 4:
                rows.append({
                    "rid": parts[0], "text": parts[1],
                    "done": parts[2].strip().lower() == "true",
                    "due": parts[3].strip() or None,
                })
        return rows

    rows = parse(osa(script))
    # Reminders.app answers with nothing while it is busy writing. An empty
    # answer is indistinguishable from a genuinely empty list, and acting on it
    # would re-create every task, so confirm empties before believing them.
    for _ in range(3):
        if rows:
            break
        time.sleep(1.5)
        rows = parse(osa(script))
    return rows


def _due_clause(due):
    if not due:
        return ""
    y, m, d = due.split("-")
    return (
        ', due date:(current date) - (time of (current date)) + 9 * hours '
        '+ 0 * days'
    ) if False else (
        ', due date:(my makeDate(%s, %s, %s))' % (int(y), int(m), int(d))
    )


MAKE_DATE = '''
on makeDate(y, m, d)
  set dd to current date
  set year of dd to y
  set month of dd to m
  set day of dd to d
  set time of dd to 9 * hours
  return dd
end makeDate
'''


def rem_create(list_name, text, due):
    script = MAKE_DATE + '''
    tell application "Reminders"
      set r to make new reminder at end of list "%s" with properties {name:"%s"%s}
      return id of r
    end tell''' % (
        list_name.replace('"', '\\"'),
        text.replace("\\", "\\\\").replace('"', '\\"'),
        _due_clause(due),
    )
    return osa(script)


def rem_update(rid, done=None, text=None, due=None):
    sets = []
    if done is not None:
        sets.append("set completed of r to %s" % ("true" if done else "false"))
    if text is not None:
        sets.append('set name of r to "%s"' % text.replace("\\", "\\\\").replace('"', '\\"'))
    if due is not None:
        y, m, d = due.split("-")
        sets.append("set due date of r to (my makeDate(%d, %d, %d))" % (int(y), int(m), int(d)))
    if not sets:
        return
    script = MAKE_DATE + '''
    tell application "Reminders"
      set r to first reminder whose id is "%s"
      %s
    end tell''' % (rid, "\n      ".join(sets))
    osa(script)


# ------------------------------------------------------------------ Notion

def notion_token():
    try:
        with open(NOTION_TOKEN_FILE) as f:
            return f.read().strip()
    except OSError:
        sys.exit(
            "No Notion token found at ~/.notion_token.\n"
            "Create a Notion integration (notion.so/my-integrations), copy its\n"
            "secret, and save it there:  echo 'secret_xxx' > ~/.notion_token"
        )


def notion_api(method, path, body=None, token=None):
    tok = token or notion_token()
    req = urllib.request.Request(
        "https://api.notion.com/v1" + path, method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": "Bearer " + tok,
                 "Notion-Version": "2022-06-28",
                 "Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=45) as r:
            return json.load(r)
    except urllib.error.HTTPError as e:
        detail = e.read().decode()[:400]
        if e.code in (401, 403):
            sys.exit("Notion denied access (%d). Make sure the database is shared "
                     "with your integration.\n%s" % (e.code, detail))
        if e.code == 404:
            sys.exit("Notion database not found (404). Check the ID, and that it's "
                     "shared with your integration.\n%s" % detail)
        raise SystemExit("Notion error %d: %s" % (e.code, detail))


def _plain(rich):
    return "".join(x.get("plain_text", "") for x in (rich or []))


def notion_fetch(db_id, token):
    """All pages in the shared database as dicts."""
    rows, cursor = [], None
    while True:
        body = {"page_size": 100}
        if cursor:
            body["start_cursor"] = cursor
        r = notion_api("POST", "/databases/%s/query" % db_id, body, token)
        for pg in r.get("results", []):
            p = pg.get("properties", {})
            rows.append({
                "nid": pg["id"],
                "text": _plain(p.get("Name", {}).get("title")),
                "done": bool(p.get("Done", {}).get("checkbox")),
                "due": ((p.get("Due", {}).get("date") or {}) or {}).get("start"),
                "note": _plain(p.get("Note", {}).get("rich_text")),
                "addedBy": _plain(p.get("Added by", {}).get("rich_text")),
            })
        if not r.get("has_more"):
            break
        cursor = r.get("next_cursor")
    return rows


def _props(t, who=None):
    p = {
        "Name": {"title": [{"text": {"content": t.get("text", "")[:2000]}}]},
        "Done": {"checkbox": bool(t.get("done"))},
    }
    due = t.get("due")
    p["Due"] = {"date": {"start": due} if due else None}
    note = t.get("note") or ""
    p["Note"] = {"rich_text": [{"text": {"content": note[:2000]}}] if note else []}
    if who is not None:
        p["Added by"] = {"rich_text": [{"text": {"content": who[:200]}}] if who else []}
    return p


def notion_create(db_id, token, t, who):
    r = notion_api("POST", "/pages",
                   {"parent": {"database_id": db_id}, "properties": _props(t, who)},
                   token)
    return r["id"]


def notion_update(nid, token, t):
    notion_api("PATCH", "/pages/" + nid, {"properties": _props(t)}, token)


def notion_archive(nid, token):
    notion_api("PATCH", "/pages/" + nid, {"archived": True}, token)


def _relink_shared(state):
    """When linking a different database, drop stale page ids so shared tasks
    re-sync into the new one instead of pointing at the old (or a deleted) DB."""
    for t in state["tasks"]:
        if t.get("space") == "shared":
            t.pop("nid", None)


def _first_parent_page(token):
    """A page the integration can write under, to host the new database.
    (Notion can't create workspace-root pages via API, so we nest under an
    accessible page; the user can Move it wherever afterwards.)"""
    r = notion_api("POST", "/search",
                   {"filter": {"value": "page", "property": "object"},
                    "page_size": 1}, token)
    res = r.get("results", [])
    if not res:
        sys.exit("Your Notion integration can't see any page to create the list "
                 "under. Share at least one page with the integration first.")
    return res[0]["id"]


def whoami():
    who = os.environ.get("USER") or "someone"
    try:
        me = notion_api("GET", "/users/me")
        n = me.get("name")
        if n:
            who = n
    except SystemExit:
        pass
    return who


def notion_sync(_ignored=None, verbose=True):
    """Two-way sync between the widget's shared tasks and a Notion database.

    Same guards as the Reminders sync: an exclusive lock with a fresh state read
    inside it, title-based adoption, and a safety bail if Notion returns empty
    while we already have linked shared tasks.
    """
    os.makedirs(DATA_DIR, exist_ok=True)
    lock = open(NOTION_LOCK, "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except IOError as e:
        if e.errno in (errno.EAGAIN, errno.EACCES):
            if verbose:
                print("Another shared-list sync is already running; skipped.")
            return load()
        raise
    try:
        return _notion_sync_locked(verbose)
    finally:
        fcntl.flock(lock, fcntl.LOCK_UN)
        lock.close()


def _notion_sync_locked(verbose):
    state = load()
    cfg = state.get("notion") or {}
    db_id = cfg.get("db")
    if not db_id:
        sys.exit("No shared list linked. Run: today share new \"NAME\"  (or share join DBID)")
    token = notion_token()
    who = cfg.get("me") or whoami()
    remote = {r["nid"]: r for r in notion_fetch(db_id, token)}

    tasks = state["tasks"]
    shared = [t for t in tasks if t.get("space") == "shared"]
    today = today_str()
    created = updated = imported = dropped = adopted = 0

    if not remote and any(t.get("nid") for t in shared):
        if verbose:
            print("Notion returned an empty database unexpectedly; skipped this sync.")
        return state

    claimed = {t.get("nid") for t in shared if t.get("nid")}
    unclaimed = {}
    for nid, r in remote.items():
        if nid not in claimed:
            unclaimed.setdefault(r["text"].strip(), []).append(nid)

    # widget -> Notion. Track pages we just wrote so the pull-back below (which
    # uses the pre-push snapshot) doesn't revert this cycle's local edits.
    touched = set()

    for t in shared:
        nid = t.get("nid")
        if not nid:
            same = unclaimed.get((t.get("text") or "").strip())
            if same:
                t["nid"] = nid = same.pop(0)
                adopted += 1
        if nid and nid in remote:
            r = remote[nid]
            if (bool(t.get("done")) != r["done"]
                    or (t.get("text") or "") != r["text"]
                    or (t.get("due") or None) != (r["due"] or None)
                    or (t.get("note") or "") != (r["note"] or "")):
                notion_update(nid, token, t)
                touched.add(nid)
                updated += 1
        elif nid:
            t["_gone"] = True
            dropped += 1
        else:
            t["nid"] = notion_create(db_id, token, t, who)
            t.setdefault("addedBy", who)
            touched.add(t["nid"])
            created += 1

    if dropped:
        state["tasks"] = [t for t in tasks if not t.get("_gone")]
        tasks = state["tasks"]

    # Notion -> widget
    known = {t.get("nid") for t in tasks if t.get("nid")}
    for nid, r in remote.items():
        if nid in known:
            continue
        tasks.append({
            "id": format(int(time.time() * 1000), "x") + str(imported),
            "text": r["text"], "done": r["done"], "space": "shared",
            "due": r["due"] or today, "note": r["note"], "nid": nid,
            "addedBy": r["addedBy"] or "",
            **({"doneAt": time.strftime("%H:%M"), "doneOn": today} if r["done"] else {}),
        })
        imported += 1

    # edits coming from Notion — but never for pages we just pushed, whose
    # snapshot in `remote` is now stale (that would revert this cycle's edits).
    for t in tasks:
        if t.get("space") != "shared":
            continue
        nid = t.get("nid")
        if nid in touched:
            continue
        r = remote.get(nid)
        if not r:
            continue
        if r["done"] and not t.get("done"):
            t["done"] = True
            t.setdefault("doneAt", time.strftime("%H:%M"))
            t.setdefault("doneOn", today)
        if r["text"] and r["text"] != t.get("text"):
            t["text"] = r["text"]
        if (r["note"] or "") != (t.get("note") or ""):
            t["note"] = r["note"]
        if r["addedBy"] and not t.get("addedBy"):
            t["addedBy"] = r["addedBy"]

    save(state)
    if verbose:
        bits = [("%d %s" % (n, l)) for n, l in
                ((created, "created"), (imported, "imported"), (adopted, "matched"),
                 (updated, "updated"), (dropped, "removed")) if n]
        print("Shared list synced with Notion: %s" % (", ".join(bits) or "already in sync"))
    return state


LOCK_FILE = os.path.join(DATA_DIR, "sync.lock")
NOTION_LOCK = os.path.join(DATA_DIR, "notion.lock")


def sync(_ignored=None, verbose=True):
    """Two-way sync between the widget and one Reminders list.

    Holds an exclusive lock and re-reads state inside it, so a manual `today
    sync` and the app's background sync can never duplicate each other's work.
    """
    os.makedirs(DATA_DIR, exist_ok=True)
    lock = open(LOCK_FILE, "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except IOError as e:
        if e.errno in (errno.EAGAIN, errno.EACCES):
            if verbose:
                print("Another sync is already running; skipped.")
            return load()
        raise
    try:
        return _sync_locked(verbose)
    finally:
        fcntl.flock(lock, fcntl.LOCK_UN)
        lock.close()


def _sync_locked(verbose):
    state = load()  # fresh read inside the lock
    list_name = state.get("remindersList")
    if not list_name:
        sys.exit("No list linked yet. Run: today sync list \"Tasks\"")
    remote = {r["rid"]: r for r in rem_fetch(list_name)}
    tasks = state["tasks"]
    today = today_str()
    created = updated = imported = dropped = adopted = 0

    # Safety net: if we already linked reminders but the list reads as empty,
    # something is wrong with Reminders rather than genuinely empty. Bail out
    # instead of duplicating everything or wiping the links.
    if not remote and any(t.get("rid") for t in tasks):
        if verbose:
            print("Reminders returned an empty list unexpectedly; skipped this sync.")
        return state

    # Reminders that no task claims yet, keyed by title — lets a task adopt an
    # existing reminder instead of creating a duplicate.
    claimed = {t.get("rid") for t in tasks if t.get("rid")}
    unclaimed = {}
    for rid, r in remote.items():
        if rid not in claimed:
            unclaimed.setdefault(r["text"].strip(), []).append(rid)

    # widget -> Reminders
    for t in tasks:
        rid = t.get("rid")
        if not rid:
            same = unclaimed.get((t.get("text") or "").strip())
            if same:
                t["rid"] = rid = same.pop(0)
                adopted += 1
        if rid and rid in remote:
            r = remote[rid]
            changes = {}
            if bool(t.get("done")) != r["done"]:
                changes["done"] = bool(t.get("done"))
            if t.get("text") != r["text"]:
                changes["text"] = t.get("text")
            if t.get("due") and t["due"] != r["due"]:
                changes["due"] = t["due"]
            if changes:
                rem_update(rid, **changes)
                updated += 1
        elif rid:
            # the reminder was deleted in Reminders.app
            t["_gone"] = True
            dropped += 1
        else:
            t["rid"] = rem_create(list_name, t.get("text", ""), t.get("due"))
            created += 1

    if dropped:
        state["tasks"] = [t for t in tasks if not t.get("_gone")]
        tasks = state["tasks"]

    # Reminders -> widget
    known = {t.get("rid") for t in tasks}
    for rid, r in remote.items():
        if rid in known:
            continue
        if r["done"]:
            continue  # don't import already-finished reminders
        tasks.append({
            "id": format(int(time.time() * 1000), "x") + str(imported),
            "text": r["text"], "done": False,
            "due": r["due"] or today, "rid": rid,
        })
        imported += 1

    # completion coming from Reminders
    for t in tasks:
        r = remote.get(t.get("rid"))
        if r and r["done"] and not t.get("done"):
            t["done"] = True
            t.setdefault("doneAt", time.strftime("%H:%M"))
            t.setdefault("doneOn", today)

    save(state)
    if verbose:
        bits = []
        for n, label in ((created, "created"), (imported, "imported"),
                         (adopted, "matched"), (updated, "updated"),
                         (dropped, "removed")):
            if n:
                bits.append("%d %s" % (n, label))
        print("Synced with \"%s\": %s" % (list_name, ", ".join(bits) or "already in sync"))
    return state


def show(state):
    tasks = state["tasks"]
    if not tasks:
        print("No tasks.")
        return
    today = today_str()
    buckets = [
        ("CARRIED OVER", lambda t: not t.get("done") and t.get("due", today) < today),
        ("TODAY", lambda t: not t.get("done") and t.get("due", today) == today),
        ("UPCOMING", lambda t: not t.get("done") and t.get("due", today) > today),
        ("DONE", lambda t: t.get("done")),
    ]
    open_n = sum(1 for t in tasks if not t.get("done") and t.get("due", today) <= today)
    done_n = sum(1 for t in tasks if t.get("done"))
    print("Today  (%d done, %d open)" % (done_n, open_n))
    for label, pred in buckets:
        rows = [(i, t) for i, t in enumerate(tasks, 1) if pred(t)]
        if not rows:
            continue
        print("\n  %s" % label)
        for i, t in rows:
            mark = "x" if t.get("done") else " "
            due = t.get("due", today)
            tag = ""
            if not t.get("done") and due != today:
                tag = "  (%s)" % due
            print("  %2d. [%s] %s%s" % (i, mark, t.get("text", ""), tag))
            for line in (t.get("note") or "").splitlines():
                if line.strip():
                    print("        | %s" % line.strip())


def pick(state, args):
    idxs = []
    for a in args:
        try:
            n = int(a)
        except ValueError:
            sys.exit("Not a task number: %r (run `today` to see numbers)" % a)
        if not 1 <= n <= len(state["tasks"]):
            sys.exit("No task #%d (there are %d tasks)" % (n, len(state["tasks"])))
        idxs.append(n - 1)
    return idxs


def main():
    state = load()
    args = sys.argv[1:]
    cmd = args[0] if args else "list"

    if cmd == "list" or not args:
        show(state)
        return
    if cmd == "add":
        rest = args[1:]
        due = today_str()
        shared = False
        if "--shared" in rest:
            rest.remove("--shared")
            shared = True
        for flag in ("--when", "--on", "--in"):
            if flag in rest:
                k = rest.index(flag)
                if k + 1 >= len(rest):
                    sys.exit("Usage: today add TEXT %s WHEN" % flag)
                due = parse_when(rest[k + 1])
                rest = rest[:k] + rest[k + 2:]
        text = " ".join(rest).strip()
        if not text:
            sys.exit("Usage: today add TEXT [--shared] [--when tomorrow|+3|YYYY-MM-DD]")
        t = {"id": format(int(time.time() * 1000), "x"),
             "text": text, "done": False, "due": due}
        if shared:
            t["space"] = "shared"
        state["tasks"].append(t)
        if shared and (state.get("notion") or {}).get("db"):
            save(state); state = notion_sync(); show(state); return
    elif cmd in ("done", "undo"):
        for i in pick(state, args[1:]):
            state["tasks"][i]["done"] = cmd == "done"
            if cmd == "done":
                state["tasks"][i]["doneAt"] = time.strftime("%H:%M")
            else:
                state["tasks"][i].pop("doneAt", None)
    elif cmd == "rm":
        for i in sorted(pick(state, args[1:]), reverse=True):
            del state["tasks"][i]
    elif cmd == "clear":
        state["tasks"] = [t for t in state["tasks"] if not t.get("done")]
    elif cmd == "sync":
        sub = args[1] if len(args) > 1 else ""
        if sub == "list":
            if len(args) < 3:
                sys.exit('Usage: today sync list "Tasks"')
            name = " ".join(args[2:])
            names = [n.strip() for n in osa(
                'tell application "Reminders" to get name of every list'
            ).split(",")]
            if name not in names:
                sys.exit("No Reminders list called %r. Yours: %s" % (name, ", ".join(names)))
            state["remindersList"] = name
            state["syncOn"] = True
            save(state)
            print('Linked to "%s". Syncing now…' % name)
            state = sync()
            show(state)
            return
        elif sub in ("on", "off"):
            state["syncOn"] = sub == "on"
            if sub == "on" and not state.get("remindersList"):
                sys.exit('Pick a list first: today sync list "Tasks"')
            save(state)
            print("Automatic sync %s" % ("ON (every 60s)" if sub == "on" else "OFF"))
            return
        elif sub == "status":
            print("List:  %s" % (state.get("remindersList") or "(none linked)"))
            print("Auto:  %s" % ("on" if state.get("syncOn") else "off"))
            linked = sum(1 for t in state["tasks"] if t.get("rid"))
            print("Linked tasks: %d of %d" % (linked, len(state["tasks"])))
            return
        else:
            show(sync())
            return
    elif cmd == "share":
        sub = args[1] if len(args) > 1 else ""
        cfg = state.get("notion") or {}
        if sub == "new":
            if len(args) < 3:
                sys.exit('Usage: today share new "Lab shared"')
            name = " ".join(args[2:])
            token = notion_token()
            me = whoami()
            # Create a container page (Private space) + the database inside it.
            page = notion_api("POST", "/pages", {
                "parent": {"type": "workspace", "workspace": True}
                if False else {"page_id": _first_parent_page(token)},
                "properties": {"title": {"title": [{"text": {"content": name}}]}},
            }, token)
            db = notion_api("POST", "/databases", {
                "parent": {"page_id": page["id"]},
                "title": [{"text": {"content": name}}],
                "properties": {
                    "Name": {"title": {}}, "Done": {"checkbox": {}},
                    "Due": {"date": {}}, "Note": {"rich_text": {}},
                    "Added by": {"rich_text": {}},
                },
            }, token)
            state["notion"] = {"db": db["id"], "name": name, "me": me, "on": True}
            _relink_shared(state)  # clear nids from a previous database
            save(state)
            url = db.get("url", "https://notion.so/" + db["id"].replace("-", ""))
            print('Created shared list "%s".' % name)
            print("  Database: %s" % url)
            print("  Share that page with your coworker in Notion, then have them run:")
            print("    today share join %s" % db["id"])
            state = notion_sync()
            show(state)
            return
        elif sub == "join":
            if len(args) < 3:
                sys.exit('Usage: today share join DATABASE_ID ["List name"]')
            db_id = args[2].strip()
            name = " ".join(args[3:]).strip() or cfg.get("name") or "Shared"
            token = notion_token()
            notion_api("GET", "/databases/" + db_id, None, token)  # validate access
            state["notion"] = {"db": db_id, "name": name,
                               "me": whoami(), "on": True}
            _relink_shared(state)  # clear nids from a previous database
            save(state)
            print("Linked to the shared database. Syncing…")
            state = notion_sync()
            show(state)
            return
        elif sub == "sync":
            show(notion_sync())
            return
        elif sub == "off":
            if cfg:
                cfg["on"] = False
                state["notion"] = cfg
                save(state)
            print("Shared-list sync OFF")
            return
        elif sub == "status":
            if not cfg.get("db"):
                print("Shared list: (none linked)")
            else:
                print("Shared list: %s" % cfg.get("name", "Shared"))
                print("Database:    %s" % cfg["db"])
                print("Auto sync:   %s" % ("on" if cfg.get("on") else "off"))
                n = sum(1 for t in state["tasks"] if t.get("space") == "shared")
                print("Shared tasks: %d" % n)
            return
        else:
            # `today share N [N...]` — move tasks into the shared list
            for i in pick(state, args[1:]):
                state["tasks"][i]["space"] = "shared"
                state["tasks"][i].pop("rid", None)  # leave Reminders; it's shared now
            save(state)
            if cfg.get("db"):
                state = notion_sync()
            show(state)
            return
    elif cmd == "unshare":
        for i in pick(state, args[1:]):
            t = state["tasks"][i]
            t.pop("space", None)
            nid = t.pop("nid", None)
            t.pop("addedBy", None)
            if nid and (state.get("notion") or {}).get("db"):
                try:
                    notion_archive(nid, notion_token())
                except SystemExit:
                    pass
    elif cmd == "when":
        if len(args) < 3:
            sys.exit("Usage: today when N today|tomorrow|+3|YYYY-MM-DD")
        i = pick(state, args[1:2])[0]
        state["tasks"][i]["due"] = parse_when(args[2])
    elif cmd in ("note", "note+", "note-"):
        if len(args) < 2:
            sys.exit("Usage: today %s N [TEXT...]" % cmd)
        i = pick(state, args[1:2])[0]
        text = " ".join(args[2:]).strip()
        if cmd == "note-":
            state["tasks"][i].pop("note", None)
        elif cmd == "note+":
            old = state["tasks"][i].get("note", "")
            state["tasks"][i]["note"] = (old + "\n" + text).strip() if old else text
        else:
            if not text:
                sys.exit("Usage: today note N TEXT")
            state["tasks"][i]["note"] = text
    else:
        sys.exit(__doc__.strip())

    save(state)
    show(state)


if __name__ == "__main__":
    main()
